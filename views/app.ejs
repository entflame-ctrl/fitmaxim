<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Gym Management System</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    :root {
      --sidebar-w: 250px;
      --primary: #6366f1;
      --primary-dark: #4f46e5;
      --bg: #f4f6fc;
      --ink: #1e293b;
      --muted: #64748b;
      --radius: 16px;
      --shadow: 0 6px 24px rgba(30, 41, 59, .07);
      --shadow-hover: 0 12px 34px rgba(79, 70, 229, .14);
    }
    * { font-family: 'Inter', system-ui, -apple-system, sans-serif; }
    body { background: var(--bg); color: var(--ink); }

    /* Sidebar */
    .sidebar {
      position: fixed; top: 0; left: 0; bottom: 0; width: var(--sidebar-w);
      background: linear-gradient(180deg, #1e1b4b 0%, #312e81 60%, #3730a3 100%);
      color: #fff; padding: 22px 0; overflow-y: auto;
      box-shadow: 4px 0 24px rgba(30, 27, 75, .18);
    }
    .sidebar .brand {
      font-weight: 800; font-size: 21px; letter-spacing: .3px;
      padding: 0 22px 20px; margin-bottom: 8px;
      border-bottom: 1px solid rgba(255,255,255,.12);
      display: flex; align-items: center; gap: 10px;
    }
    .sidebar a {
      display: flex; align-items: center; gap: 12px;
      color: rgba(255,255,255,.72);
      padding: 12px 22px; text-decoration: none; font-size: 14.5px; font-weight: 500;
      border-left: 3px solid transparent; transition: all .18s ease;
    }
    .sidebar a .ic { font-size: 17px; width: 22px; text-align: center; }
    .sidebar a:hover { background: rgba(255,255,255,.08); color: #fff; }
    .sidebar a.active {
      background: rgba(255,255,255,.14); color: #fff;
      border-left-color: #a5b4fc; font-weight: 600;
    }

    /* Layout */
    .main { margin-left: var(--sidebar-w); }
    .navbar-top {
      background: rgba(255,255,255,.85); backdrop-filter: blur(10px);
      box-shadow: 0 1px 0 rgba(30,41,59,.06); position: sticky; top: 0; z-index: 10;
    }
    .content { padding: 26px; }
    .page-title { font-weight: 800; letter-spacing: .2px; }

    /* Cards */
    .card {
      border: none; border-radius: var(--radius); box-shadow: var(--shadow);
      transition: transform .2s ease, box-shadow .2s ease;
    }
    .stat-card { position: relative; overflow: hidden; }
    .stat-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-hover); }
    .stat-card .num { font-size: 34px; font-weight: 800; line-height: 1.1; }
    .stat-card .label { color: var(--muted); font-size: 13.5px; font-weight: 600; text-transform: uppercase; letter-spacing: .5px; }
    .stat-icon {
      width: 52px; height: 52px; border-radius: 14px; display: flex;
      align-items: center; justify-content: center; font-size: 24px;
    }
    .stat-icon.i-blue { background: #eef2ff; }
    .stat-icon.i-green { background: #ecfdf5; }
    .stat-icon.i-amber { background: #fffbeb; }

    h6.fw-bold { font-weight: 700 !important; letter-spacing: .2px; }

    /* Tables */
    .table { --bs-table-bg: transparent; }
    .table thead th {
      background: #f8fafc; color: var(--muted); font-weight: 600;
      font-size: 12.5px; text-transform: uppercase; letter-spacing: .4px;
      border-bottom: 1px solid #eef2f7; padding: 12px;
    }
    .table tbody td { padding: 12px; border-color: #f1f5f9; vertical-align: middle; }
    .table tbody tr:hover { background: #f8faff; }

    /* Forms */
    .form-control, .form-select {
      border-radius: 10px; border: 1px solid #e2e8f0; padding: .55rem .8rem; font-size: 14.5px;
    }
    .form-control:focus, .form-select:focus {
      border-color: var(--primary); box-shadow: 0 0 0 3px rgba(99,102,241,.15);
    }
    .form-label { font-weight: 600; font-size: 13px; color: var(--muted); }

    /* Buttons */
    .btn { border-radius: 10px; font-weight: 600; font-size: 14.5px; padding: .5rem 1rem; }
    .btn-primary {
      background: linear-gradient(135deg, var(--primary), var(--primary-dark));
      border: none; box-shadow: 0 4px 12px rgba(99,102,241,.3);
    }
    .btn-primary:hover { background: linear-gradient(135deg, var(--primary-dark), #4338ca); transform: translateY(-1px); }
    .btn-outline-primary { border-color: var(--primary); color: var(--primary); }
    .btn-outline-primary:hover { background: var(--primary); border-color: var(--primary); }
    .btn-success { background: linear-gradient(135deg, #10b981, #059669); border: none; }
    .btn-sm { padding: .3rem .7rem; font-size: 13px; }

    /* Badges & alerts */
    .badge { font-weight: 600; padding: .4em .7em; border-radius: 7px; }
    .alert { border: none; border-radius: 12px; font-weight: 500; }
    .alert-success { background: #ecfdf5; color: #047857; }
  </style>
</head>
<body>
  <%
    const nav = [
      ["dashboard", "Dashboard", "📊"],
      ["members", "Members", "👥"],
      ["plans", "Plans", "📋"],
      ["payments", "Payments", "💳"],
      ["attendance", "Attendance", "📅"],
      ["trainers", "Trainers", "🏋️"],
      ["progress", "Progress", "📈"],
      ["reminders", "Reminders", "💬"]
    ];
    function money(n){ return "$" + Number(n || 0).toFixed(2); }
    function fdate(d){ return d ? new Date(d).toLocaleDateString() : "-"; }
    function ftime(d){ return d ? new Date(d).toLocaleString() : "-"; }
  %>

  <!-- Sidebar -->
  <div class="sidebar">
    <div class="brand"><span>💪</span> <span>GymManager</span></div>
    <% nav.forEach(function(item){ %>
      <a href="/app?page=<%= item[0] %>" class="<%= page === item[0] ? 'active' : '' %>">
        <span class="ic"><%= item[2] %></span> <span><%= item[1] %></span>
      </a>
    <% }); %>
  </div>

  <!-- Main -->
  <div class="main">
    <nav class="navbar navbar-top px-4 py-3 d-flex justify-content-between align-items-center">
      <h5 class="mb-0 page-title text-capitalize"><%= page %></h5>
      <div class="d-flex align-items-center gap-3">
        <span class="text-muted">👤 <%= user.name %> <span class="badge bg-secondary"><%= user.role %></span></span>
        <a href="/logout" class="btn btn-sm btn-outline-danger">Logout</a>
      </div>
    </nav>

    <div class="content">
      <% if (success_msg) { %>
        <div class="alert alert-success"><%= success_msg %></div>
      <% } %>

      <!-- ================= DASHBOARD ================= -->
      <% if (page === "dashboard") { %>
        <div class="row g-4">
          <div class="col-md-4">
            <div class="card stat-card p-4">
              <div class="d-flex justify-content-between align-items-start">
                <div>
                  <div class="label mb-1">Total Members</div>
                  <div class="num text-primary"><%= stats.total_members %></div>
                </div>
                <div class="stat-icon i-blue">👥</div>
              </div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="card stat-card p-4">
              <div class="d-flex justify-content-between align-items-start">
                <div>
                  <div class="label mb-1">Active Members</div>
                  <div class="num text-success"><%= stats.active_members %></div>
                </div>
                <div class="stat-icon i-green">✅</div>
              </div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="card stat-card p-4">
              <div class="d-flex justify-content-between align-items-start">
                <div>
                  <div class="label mb-1">Total Revenue</div>
                  <div class="num text-dark"><%= money(stats.total_revenue) %></div>
                </div>
                <div class="stat-icon i-amber">💰</div>
              </div>
            </div>
          </div>
        </div>
      <% } %>

      <!-- ================= MEMBERS ================= -->
      <% if (page === "members") { %>
        <div class="row g-4">
          <div class="col-lg-4">
            <div class="card p-4">
              <h6 class="fw-bold mb-3">Add Member</h6>
              <form method="POST" action="/app">
                <input type="hidden" name="action" value="add_member" />
                <input type="hidden" name="page" value="members" />
                <div class="mb-2"><input name="first_name" class="form-control" placeholder="First name" required /></div>
                <div class="mb-2"><input name="last_name" class="form-control" placeholder="Last name" required /></div>
                <div class="mb-2"><input name="phone" class="form-control" placeholder="Phone" /></div>
                <div class="mb-2"><input name="email" type="email" class="form-control" placeholder="Email" /></div>
                <div class="mb-2">
                  <select name="gender" class="form-select">
                    <option value="">Gender</option>
                    <option>Male</option><option>Female</option><option>Other</option>
                  </select>
                </div>
                <button class="btn btn-primary w-100">Add Member</button>
              </form>
            </div>

            <div class="card p-4 mt-4">
              <h6 class="fw-bold mb-3">Assign Plan</h6>
              <form method="POST" action="/app">
                <input type="hidden" name="action" value="assign_plan" />
                <input type="hidden" name="page" value="members" />
                <div class="mb-2">
                  <select name="member_id" class="form-select" required>
                    <option value="">Select member</option>
                    <% members.forEach(function(m){ %>
                      <option value="<%= m.id %>"><%= m.first_name %> <%= m.last_name %> (<%= m.membership_id %>)</option>
                    <% }); %>
                  </select>
                </div>
                <div class="mb-2">
                  <select name="plan_id" class="form-select" required>
                    <option value="">Select plan</option>
                    <% plans.forEach(function(p){ %>
                      <option value="<%= p.id %>"><%= p.name %> — <%= money(p.price) %></option>
                    <% }); %>
                  </select>
                </div>
                <button class="btn btn-outline-primary w-100">Assign Plan</button>
              </form>
            </div>
          </div>

          <div class="col-lg-8">
            <div class="card p-4">
              <h6 class="fw-bold mb-3">Members List</h6>
              <div class="table-responsive">
                <table class="table align-middle">
                  <thead><tr>
                    <th>ID</th><th>Name</th><th>Phone</th><th>Join</th><th>Status</th><th></th>
                  </tr></thead>
                  <tbody>
                    <% members.forEach(function(m){ %>
                      <tr>
                        <td><%= m.membership_id %></td>
                        <td><%= m.first_name %> <%= m.last_name %></td>
                        <td><%= m.phone || "-" %></td>
                        <td><%= fdate(m.join_date) %></td>
                        <td><span class="badge bg-<%= m.status === 'active' ? 'success' : 'secondary' %>"><%= m.status %></span></td>
                        <td><a href="/app?page=members&delete_member=<%= m.id %>" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this member?')">Delete</a></td>
                      </tr>
                    <% }); %>
                    <% if (members.length === 0) { %><tr><td colspan="6" class="text-center text-muted">No members yet.</td></tr><% } %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      <% } %>

      <!-- ================= PLANS ================= -->
      <% if (page === "plans") { %>
        <div class="row g-4">
          <div class="col-lg-4">
            <div class="card p-4">
              <h6 class="fw-bold mb-3">Add Plan</h6>
              <form method="POST" action="/app">
                <input type="hidden" name="action" value="add_plan" />
                <input type="hidden" name="page" value="plans" />
                <div class="mb-2"><input name="name" class="form-control" placeholder="Plan name" required /></div>
                <div class="mb-2"><input name="duration_days" type="number" class="form-control" placeholder="Duration (days)" required /></div>
                <div class="mb-2"><input name="price" type="number" step="0.01" class="form-control" placeholder="Price" required /></div>
                <button class="btn btn-primary w-100">Add Plan</button>
              </form>
            </div>
          </div>
          <div class="col-lg-8">
            <div class="card p-4">
              <h6 class="fw-bold mb-3">Plans List</h6>
              <div class="table-responsive">
                <table class="table align-middle">
                  <thead><tr><th>Name</th><th>Duration</th><th>Price</th><th></th></tr></thead>
                  <tbody>
                    <% plans.forEach(function(p){ %>
                      <tr>
                        <td><%= p.name %></td>
                        <td><%= p.duration_days %> days</td>
                        <td><%= money(p.price) %></td>
                        <td><a href="/app?page=plans&delete_plan=<%= p.id %>" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this plan?')">Delete</a></td>
                      </tr>
                    <% }); %>
                    <% if (plans.length === 0) { %><tr><td colspan="4" class="text-center text-muted">No plans yet.</td></tr><% } %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      <% } %>

      <!-- ================= PAYMENTS ================= -->
      <% if (page === "payments") { %>
        <div class="row g-4">
          <div class="col-lg-4">
            <div class="card p-4">
              <h6 class="fw-bold mb-3">Record Payment</h6>
              <form method="POST" action="/app">
                <input type="hidden" name="action" value="add_payment" />
                <input type="hidden" name="page" value="payments" />
                <div class="mb-2">
                  <select name="member_id" class="form-select" required>
                    <option value="">Select member</option>
                    <% members.forEach(function(m){ %>
                      <option value="<%= m.id %>"><%= m.first_name %> <%= m.last_name %> (<%= m.membership_id %>)</option>
                    <% }); %>
                  </select>
                </div>
                <div class="mb-2"><input name="amount" type="number" step="0.01" class="form-control" placeholder="Amount" required /></div>
                <div class="mb-2">
                  <select name="payment_method" class="form-select">
                    <option value="cash">Cash</option>
                    <option value="card">Card</option>
                    <option value="upi">UPI</option>
                    <option value="bank">Bank Transfer</option>
                  </select>
                </div>
                <button class="btn btn-primary w-100">Record Payment</button>
              </form>
            </div>
          </div>
          <div class="col-lg-8">
            <div class="card p-4">
              <h6 class="fw-bold mb-3">Payments</h6>
              <div class="table-responsive">
                <table class="table align-middle">
                  <thead><tr><th>Member</th><th>Amount</th><th>Method</th><th>Date</th></tr></thead>
                  <tbody>
                    <% payments.forEach(function(p){ %>
                      <tr>
                        <td><%= p.member ? p.member.first_name + " " + p.member.last_name : "-" %></td>
                        <td><%= money(p.amount) %></td>
                        <td><span class="badge bg-info text-dark"><%= p.payment_method %></span></td>
                        <td><%= ftime(p.payment_date) %></td>
                      </tr>
                    <% }); %>
                    <% if (payments.length === 0) { %><tr><td colspan="4" class="text-center text-muted">No payments yet.</td></tr><% } %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      <% } %>

      <!-- ================= ATTENDANCE ================= -->
      <% if (page === "attendance") { %>
        <div class="row g-4">
          <div class="col-lg-4">
            <div class="card p-4">
              <h6 class="fw-bold mb-3">Check In</h6>
              <form method="POST" action="/app" class="mb-4">
                <input type="hidden" name="action" value="checkin_member" />
                <input type="hidden" name="page" value="attendance" />
                <div class="mb-2">
                  <select name="member_id" class="form-select" required>
                    <option value="">Select member</option>
                    <% members.forEach(function(m){ %>
                      <option value="<%= m.id %>"><%= m.first_name %> <%= m.last_name %></option>
                    <% }); %>
                  </select>
                </div>
                <button class="btn btn-success w-100">Check In</button>
              </form>

              <h6 class="fw-bold mb-3">Check Out</h6>
              <form method="POST" action="/app">
                <input type="hidden" name="action" value="checkout_member" />
                <input type="hidden" name="page" value="attendance" />
                <div class="mb-2">
                  <select name="member_id" class="form-select" required>
                    <option value="">Select member</option>
                    <% members.forEach(function(m){ %>
                      <option value="<%= m.id %>"><%= m.first_name %> <%= m.last_name %></option>
                    <% }); %>
                  </select>
                </div>
                <button class="btn btn-warning w-100">Check Out</button>
              </form>
            </div>
          </div>
          <div class="col-lg-8">
            <div class="card p-4">
              <h6 class="fw-bold mb-3">Attendance Logs</h6>
              <div class="table-responsive">
                <table class="table align-middle">
                  <thead><tr><th>Member</th><th>Check In</th><th>Check Out</th></tr></thead>
                  <tbody>
                    <% attendance.forEach(function(a){ %>
                      <tr>
                        <td><%= a.member ? a.member.first_name + " " + a.member.last_name : "-" %></td>
                        <td><%= ftime(a.check_in) %></td>
                        <td><%= a.check_out ? ftime(a.check_out) : '<span class="badge bg-success">In Gym</span>' %></td>
                      </tr>
                    <% }); %>
                    <% if (attendance.length === 0) { %><tr><td colspan="3" class="text-center text-muted">No logs yet.</td></tr><% } %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      <% } %>

      <!-- ================= TRAINERS ================= -->
      <% if (page === "trainers") { %>
        <div class="row g-4">
          <div class="col-lg-4">
            <div class="card p-4">
              <h6 class="fw-bold mb-3">Add Trainer</h6>
              <form method="POST" action="/app">
                <input type="hidden" name="action" value="add_trainer" />
                <input type="hidden" name="page" value="trainers" />
                <div class="mb-2"><input name="name" class="form-control" placeholder="Trainer name" required /></div>
                <div class="mb-2"><input name="phone" class="form-control" placeholder="Phone" /></div>
                <div class="mb-2"><input name="specialization" class="form-control" placeholder="Specialization" /></div>
                <button class="btn btn-primary w-100">Add Trainer</button>
              </form>
            </div>

            <div class="card p-4 mt-4">
              <h6 class="fw-bold mb-3">Assign Trainer</h6>
              <form method="POST" action="/app">
                <input type="hidden" name="action" value="assign_trainer" />
                <input type="hidden" name="page" value="trainers" />
                <div class="mb-2">
                  <select name="member_id" class="form-select" required>
                    <option value="">Select member</option>
                    <% members.forEach(function(m){ %>
                      <option value="<%= m.id %>"><%= m.first_name %> <%= m.last_name %></option>
                    <% }); %>
                  </select>
                </div>
                <div class="mb-2">
                  <select name="trainer_id" class="form-select" required>
                    <option value="">Select trainer</option>
                    <% trainers.forEach(function(t){ %>
                      <option value="<%= t.id %>"><%= t.name %></option>
                    <% }); %>
                  </select>
                </div>
                <button class="btn btn-outline-primary w-100">Assign Trainer</button>
              </form>
            </div>
          </div>

          <div class="col-lg-8">
            <div class="card p-4">
              <h6 class="fw-bold mb-3">Trainers</h6>
              <div class="table-responsive">
                <table class="table align-middle">
                  <thead><tr><th>Name</th><th>Phone</th><th>Specialization</th><th></th></tr></thead>
                  <tbody>
                    <% trainers.forEach(function(t){ %>
                      <tr>
                        <td><%= t.name %></td>
                        <td><%= t.phone || "-" %></td>
                        <td><%= t.specialization || "-" %></td>
                        <td><a href="/app?page=trainers&delete_trainer=<%= t.id %>" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this trainer?')">Delete</a></td>
                      </tr>
                    <% }); %>
                    <% if (trainers.length === 0) { %><tr><td colspan="4" class="text-center text-muted">No trainers yet.</td></tr><% } %>
                  </tbody>
                </table>
              </div>
            </div>

            <div class="card p-4 mt-4">
              <h6 class="fw-bold mb-3">Trainer Assignments</h6>
              <div class="table-responsive">
                <table class="table align-middle">
                  <thead><tr><th>Member</th><th>Trainer</th></tr></thead>
                  <tbody>
                    <% memberTrainers.forEach(function(mt){ %>
                      <tr>
                        <td><%= mt.member ? mt.member.first_name + " " + mt.member.last_name : "-" %></td>
                        <td><%= mt.trainer ? mt.trainer.name : "-" %></td>
                      </tr>
                    <% }); %>
                    <% if (memberTrainers.length === 0) { %><tr><td colspan="2" class="text-center text-muted">No assignments yet.</td></tr><% } %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      <% } %>

      <!-- ================= PROGRESS ================= -->
      <% if (page === "progress") {
           var selMember = members.find(function(m){ return m.id === progress_member_id; });
           var labels = progress.map(function(p){ return fdate(p.date); });
           var weightData = progress.map(function(p){ return p.weight; });
           var fatData = progress.map(function(p){ return p.body_fat; });
      %>
        <div class="row g-4">
          <div class="col-lg-4">
            <div class="card p-4">
              <h6 class="fw-bold mb-3">Add Progress Entry</h6>
              <form method="POST" action="/app">
                <input type="hidden" name="action" value="add_progress" />
                <input type="hidden" name="page" value="progress" />
                <div class="mb-2">
                  <label class="form-label small text-muted mb-1">Member</label>
                  <select name="member_id" class="form-select" required>
                    <option value="">Select member</option>
                    <% members.forEach(function(m){ %>
                      <option value="<%= m.id %>" <%= m.id === progress_member_id ? "selected" : "" %>><%= m.first_name %> <%= m.last_name %> (<%= m.membership_id %>)</option>
                    <% }); %>
                  </select>
                </div>
                <div class="mb-2">
                  <label class="form-label small text-muted mb-1">Date</label>
                  <input name="date" type="date" class="form-control" />
                </div>
                <div class="row g-2">
                  <div class="col-6 mb-2"><input name="weight" type="number" step="0.1" class="form-control" placeholder="Weight (kg)" /></div>
                  <div class="col-6 mb-2"><input name="body_fat" type="number" step="0.1" class="form-control" placeholder="Body fat (%)" /></div>
                  <div class="col-6 mb-2"><input name="chest" type="number" step="0.1" class="form-control" placeholder="Chest (cm)" /></div>
                  <div class="col-6 mb-2"><input name="waist" type="number" step="0.1" class="form-control" placeholder="Waist (cm)" /></div>
                  <div class="col-6 mb-2"><input name="arms" type="number" step="0.1" class="form-control" placeholder="Arms (cm)" /></div>
                  <div class="col-6 mb-2"><input name="thighs" type="number" step="0.1" class="form-control" placeholder="Thighs (cm)" /></div>
                </div>
                <button class="btn btn-primary w-100 mt-2">Add Entry</button>
              </form>
            </div>

            <div class="card p-4 mt-4">
              <h6 class="fw-bold mb-3">View Member Progress</h6>
              <form method="GET" action="/app">
                <input type="hidden" name="page" value="progress" />
                <div class="mb-2">
                  <select name="member_id" class="form-select" onchange="this.form.submit()">
                    <option value="">Select member to view</option>
                    <% members.forEach(function(m){ %>
                      <option value="<%= m.id %>" <%= m.id === progress_member_id ? "selected" : "" %>><%= m.first_name %> <%= m.last_name %></option>
                    <% }); %>
                  </select>
                </div>
              </form>
            </div>
          </div>

          <div class="col-lg-8">
            <% if (!progress_member_id) { %>
              <div class="card p-4 text-center text-muted">
                Select a member on the left to view their fitness progress.
              </div>
            <% } else { %>
              <div class="card p-4">
                <h6 class="fw-bold mb-3">
                  📈 Progress<% if (selMember) { %> — <%= selMember.first_name %> <%= selMember.last_name %><% } %>
                </h6>
                <% if (progress.length === 0) { %>
                  <p class="text-muted mb-0">No progress entries yet for this member. Add one on the left.</p>
                <% } else { %>
                  <canvas id="progressChart" height="110"></canvas>
                <% } %>
              </div>

              <% if (progress.length > 0) { %>
                <div class="card p-4 mt-4">
                  <h6 class="fw-bold mb-3">Entries</h6>
                  <div class="table-responsive">
                    <table class="table align-middle">
                      <thead><tr>
                        <th>Date</th><th>Weight</th><th>Body Fat</th><th>Chest</th><th>Waist</th><th>Arms</th><th>Thighs</th><th></th>
                      </tr></thead>
                      <tbody>
                        <% // newest first for the table
                           progress.slice().reverse().forEach(function(p){ %>
                          <tr>
                            <td><%= fdate(p.date) %></td>
                            <td><%= p.weight != null ? p.weight + " kg" : "-" %></td>
                            <td><%= p.body_fat != null ? p.body_fat + " %" : "-" %></td>
                            <td><%= p.chest != null ? p.chest + " cm" : "-" %></td>
                            <td><%= p.waist != null ? p.waist + " cm" : "-" %></td>
                            <td><%= p.arms != null ? p.arms + " cm" : "-" %></td>
                            <td><%= p.thighs != null ? p.thighs + " cm" : "-" %></td>
                            <td><a href="/app?page=progress&delete_progress=<%= p.id %>" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this entry?')">Delete</a></td>
                          </tr>
                        <% }); %>
                      </tbody>
                    </table>
                  </div>
                </div>
              <% } %>
            <% } %>
          </div>
        </div>

        <% if (progress_member_id && progress.length > 0) { %>
          <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
          <script>
            (function(){
              var ctx = document.getElementById("progressChart");
              if (!ctx) return;
              new Chart(ctx, {
                type: "line",
                data: {
                  labels: <%- JSON.stringify(labels) %>,
                  datasets: [
                    { label: "Weight (kg)", data: <%- JSON.stringify(weightData) %>, borderColor: "#2a5298", backgroundColor: "rgba(42,82,152,.1)", tension: .3, spanGaps: true, yAxisID: "y" },
                    { label: "Body Fat (%)", data: <%- JSON.stringify(fatData) %>, borderColor: "#e67e22", backgroundColor: "rgba(230,126,34,.1)", tension: .3, spanGaps: true, yAxisID: "y1" }
                  ]
                },
                options: {
                  responsive: true,
                  interaction: { mode: "index", intersect: false },
                  scales: {
                    y: { type: "linear", position: "left", title: { display: true, text: "Weight (kg)" } },
                    y1: { type: "linear", position: "right", title: { display: true, text: "Body Fat (%)" }, grid: { drawOnChartArea: false } }
                  }
                }
              });
            })();
          </script>
        <% } %>
      <% } %>

      <!-- ================= REMINDERS ================= -->
      <% if (page === "reminders") { %>
        <div class="card p-4">
          <h6 class="fw-bold mb-1">Payment Reminders</h6>
          <p class="text-muted small mb-3">
            Members whose membership has expired or expires within 7 days.
            Click <strong>Send WhatsApp</strong> to open WhatsApp with a
            ready-to-send reminder message.
          </p>
          <div class="table-responsive">
            <table class="table align-middle">
              <thead><tr>
                <th>Member</th><th>Phone</th><th>Plan</th><th>Expiry</th><th>Status</th><th></th>
              </tr></thead>
              <tbody>
                <% reminders.forEach(function(s){
                     var digits = (s.member.phone || "").replace(/[^0-9]/g, "");
                     // Default country code: Nepal (977).
                     if (digits) {
                       if (digits.indexOf("977") === 0) {
                         // already has country code
                       } else if (digits.charAt(0) === "0") {
                         digits = "977" + digits.substring(1); // drop trunk 0
                       } else {
                         digits = "977" + digits;
                       }
                     }
                     var name = s.member.first_name;
                     var planName = s.plan ? s.plan.name : "membership";
                     var endStr = fdate(s.end_date);
                     var msg = s.expired
                       ? "Hi " + name + ", your " + planName + " membership at GymManager expired on " + endStr + ". Please renew to continue enjoying our services. Thank you!"
                       : "Hi " + name + ", a friendly reminder that your " + planName + " membership at GymManager expires on " + endStr + ". Please renew soon to avoid interruption. Thank you!";
                     var waLink = "https://wa.me/" + digits + "?text=" + encodeURIComponent(msg);
                %>
                  <tr>
                    <td><%= s.member.first_name %> <%= s.member.last_name %></td>
                    <td><%= s.member.phone || "-" %></td>
                    <td><%= planName %></td>
                    <td><%= endStr %></td>
                    <td>
                      <% if (s.expired) { %>
                        <span class="badge bg-danger">Expired</span>
                      <% } else { %>
                        <span class="badge bg-warning text-dark">Expiring soon</span>
                      <% } %>
                    </td>
                    <td>
                      <% if (digits) { %>
                        <a href="<%= waLink %>" target="_blank" rel="noopener" class="btn btn-sm btn-success">
                          💬 Send WhatsApp
                        </a>
                      <% } else { %>
                        <span class="text-muted small">No phone number</span>
                      <% } %>
                    </td>
                  </tr>
                <% }); %>
                <% if (reminders.length === 0) { %>
                  <tr><td colspan="6" class="text-center text-muted">No members need a reminder right now. 🎉</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      <% } %>

    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
